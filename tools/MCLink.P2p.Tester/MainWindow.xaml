<Window x:Class="MCLink.P2p.Tester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCLink P2P 测试器"
        Width="860"
        Height="680"
        MinWidth="780"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F7F5EF"
        FontFamily="Microsoft YaHei UI"
        Icon="Assets/mclink-world.ico"
        Closing="MainWindow_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#17231D" />
        <SolidColorBrush x:Key="MutedBrush" Color="#68736D" />
        <SolidColorBrush x:Key="GreenBrush" Color="#2F7654" />
        <SolidColorBrush x:Key="GreenHoverBrush" Color="#275F45" />
        <SolidColorBrush x:Key="LineBrush" Color="#DDE2DD" />

        <Style TargetType="Button" x:Key="PrimaryButtonStyle">
            <Setter Property="Background" Value="{StaticResource GreenBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource GreenHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E8EEE9" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DDE8DF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FBFCFA" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldLabelStyle">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="42,28,42,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="30">
            <Grid>
                <Grid x:Name="RolePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="1" Width="520">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CreateModeButton"
                                Content="创建联机"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="CreateModeButton_Click" />
                        <Button x:Name="JoinModeButton"
                                Grid.Column="2"
                                Content="加入联机"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="JoinModeButton_Click" />
                    </Grid>
                </Grid>

                <ScrollViewer x:Name="HostPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="创建联机"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="23"
                                   FontWeight="Bold" />
                        <TextBlock Text="先在 Minecraft 里对局域网开放，再填游戏显示的端口。"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="14"
                                   Margin="0,5,0,22" />

                        <TextBlock Text="Minecraft 局域网端口" Style="{StaticResource FieldLabelStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HostPortTextBox" MaxLength="5" />
                            <Button x:Name="CreateInviteButton"
                                    Grid.Column="2"
                                    Content="生成邀请码"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="CreateInviteButton_Click" />
                        </Grid>

                        <StackPanel x:Name="HostInviteSection" Visibility="Collapsed" Margin="0,22,0,0">
                            <TextBlock Text="邀请码 · 发给同学" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="InviteCodeTextBox"
                                     Height="78"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                            <Button x:Name="CopyInviteButton"
                                    Content="复制邀请码"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="CopyInviteButton_Click" />

                            <TextBlock Text="回应码 · 粘贴同学发回的内容"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Margin="0,22,0,6" />
                            <TextBox x:Name="HostResponseTextBox"
                                     Height="78"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                            <Button x:Name="AcceptResponseButton"
                                    Content="开始连接"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="AcceptResponseButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="GuestPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="加入联机"
                                   Foreground="{StaticResource InkBrush}"
                                   FontSize="23"
                                   FontWeight="Bold" />
                        <TextBlock Text="粘贴房主发来的邀请码，程序会准备回应码。"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="14"
                                   Margin="0,5,0,22" />

                        <TextBlock Text="房主邀请码" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox x:Name="GuestInviteTextBox"
                                 Height="90"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto" />
                        <Button x:Name="CreateResponseButton"
                                Content="生成回应码"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="CreateResponseButton_Click" />

                        <StackPanel x:Name="GuestResponseSection" Visibility="Collapsed" Margin="0,22,0,0">
                            <TextBlock Text="回应码 · 发回给房主" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="ResponseCodeTextBox"
                                     Height="90"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" />
                            <Button x:Name="CopyResponseButton"
                                    Content="复制回应码"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="CopyResponseButton_Click" />
                        </StackPanel>

                        <Border x:Name="LocalAddressSection"
                                Visibility="Collapsed"
                                Margin="0,24,0,0"
                                Padding="18"
                                Background="#ECF5EE"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="连接成功，在 Minecraft 里使用这个地址"
                                           Foreground="{StaticResource GreenBrush}"
                                           FontWeight="SemiBold" />
                                <TextBox x:Name="LocalAddressTextBox"
                                         Margin="0,10,0,0"
                                         IsReadOnly="True"
                                         FontSize="19"
                                         FontWeight="Bold" />
                                <Button x:Name="CopyAddressButton"
                                        Content="复制地址"
                                        HorizontalAlignment="Left"
                                        Margin="0,10,0,0"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="CopyAddressButton_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="StatusPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#93A099" Margin="0,0,9,0" />
                <StackPanel>
                    <TextBlock x:Name="StatusText"
                               Text=""
                               Foreground="{StaticResource InkBrush}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="DetailText"
                               Text=""
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12" />
                </StackPanel>
            </StackPanel>
            <Button x:Name="TutorialButton"
                    Grid.Column="1"
                    Content="教程"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="TutorialButton_Click" />
            <Button x:Name="BackButton"
                    Grid.Column="3"
                    Content="返回"
                    Visibility="Collapsed"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BackButton_Click" />
            <Button x:Name="StopButton"
                    Grid.Column="5"
                    Content="停止联机"
                    Visibility="Collapsed"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="StopButton_Click" />
        </Grid>
    </Grid>
</Window>
