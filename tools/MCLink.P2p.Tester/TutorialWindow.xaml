<Window x:Class="MCLink.P2p.Tester.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MCLink.P2p.Tester"
        Title="使用教程 · MCLink P2P 测试器"
        Width="820"
        Height="700"
        MinWidth="680"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F7F5EF"
        FontFamily="Microsoft YaHei UI"
        Icon="Assets/mclink-world.ico">
    <Grid Margin="32,26,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="MCLink 使用教程"
                       Foreground="#17231D"
                       FontSize="25"
                       FontWeight="Bold" />
            <TextBlock Text="按自己的身份查看步骤；整个过程不需要设置路由器。"
                       Foreground="#68736D"
                       FontSize="13"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DDE2DD"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">
            <TabControl FontSize="14">
                <TabItem Header="我是房主">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <TextBlock Text="{x:Static local:TutorialContent.HostSteps}"
                                   Foreground="#17231D"
                                   FontSize="14"
                                   LineHeight="24"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="我要加入">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <TextBlock Text="{x:Static local:TutorialContent.GuestSteps}"
                                   Foreground="#17231D"
                                   FontSize="14"
                                   LineHeight="24"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="常见问题">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <TextBlock Text="{x:Static local:TutorialContent.TroubleshootingSteps}"
                                   Foreground="#17231D"
                                   FontSize="14"
                                   LineHeight="24"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <Button Grid.Row="4"
                Content="关闭"
                Width="112"
                Height="42"
                HorizontalAlignment="Right"
                Background="#2F7654"
                Foreground="White"
                BorderThickness="0"
                FontSize="14"
                FontWeight="SemiBold"
                Cursor="Hand"
                Click="CloseButton_Click" />
    </Grid>
</Window>
